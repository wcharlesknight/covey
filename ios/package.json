{
  "name": "covey-ios",
  "version": "1.0.0",
  "description": "Covey iOS app - Social gathering app built with React Native and Expo",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src App.tsx --ext .ts,.tsx --max-warnings 0 2>/dev/null || true",
    "lint:fix": "eslint src App.tsx --ext .ts,.tsx --fix 2>/dev/null || true",
    "type-check": "tsc --noEmit",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform ios --profile production",
    "submit:testflight": "eas submit --platform ios --latest",
    "detox:build": "detox build-framework-cache && detox build-app",
    "detox:test": "detox test-runner",
    "detox:test:cleanup": "detox test-runner --cleanup"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@react-navigation/stack": "^6.3.0",
    "axios": "^1.6.0",
    "expo": "^51.0.0",
    "expo-apple-authentication": "^6.3.0",
    "expo-auth-session": "^5.4.0",
    "expo-notifications": "^0.28.19",
    "expo-secure-store": "^13.0.0",
    "expo-splash-screen": "^0.27.0",
    "expo-status-bar": "^1.11.0",
    "expo-web-browser": "^13.0.0",
    "firebase": "^10.7.0",
    "react": "^18.2.0",
    "react-native": "^0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.31.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-proposal-class-properties": "^7.18.0",
    "@babel/plugin-transform-flow-strip-types": "^7.23.0",
    "@babel/plugin-transform-private-methods": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-flow": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.13.0",
    "detox-cli": "^20.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "^51.0.0",
    "prettier": "^3.1.0",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
