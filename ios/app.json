{
  "expo": {
    "name": "Covey",
    "slug": "covey",
    "version": "1.0.0",
    "scheme": "covey",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B4CE6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.covery.app",
      "buildNumber": "1",
      "entitlements": {
        "aps-environment": "development"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6B4CE6"
      },
      "package": "com.covery.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icons": [
            "./assets/notification-icon.png"
          ],
          "color": "#6B4CE6"
        }
      ],
      [
        "expo-apple-authentication",
        {
          "isModal": false
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "36924851-085c-4e48-8e07-94098d4b6b7b"
      }
    },
    "owner": "williamcharlesknight"
  }
}
